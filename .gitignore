# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# production
/build

# misc
.DS_Store
*.log

# Environment variables - NEVER commit real secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# Allow .env.example to be committed (safe template only)
!.env.example

# Editor and OS files
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# npm / yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*
yarn.lock

# Optional: Python / Django backend artifacts (if you ever copy files)
__pycache__/
*.py[cod]
*.so
.Python
env/
venv/
ENV/
