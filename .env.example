##################### CLERK ##################

# Clerk publishable key (safe to commit)
# Get this from Clerk Dashboard → API Keys
REACT_APP_CLERK_PUBLISHABLE_KEY=pk_test_your_test_key_here

######################## STRIPE ########################

# Stripe publishable key (safe to commit)
# Get this from Stripe Dashboard
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key_here

######################## API ########################

# Base URL for the Django backend API
# Use http://127.0.0.1:8000 for local development
# Use https://vercel-dataflow.vercel.app for production (or your custom domain)
REACT_APP_API_BASE_URL=http://127.0.0.1:8000

# Optional: CI flag for build environments
CI=false
