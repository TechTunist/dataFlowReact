{
  "installCommand": "npm install --legacy-peer-deps",
  "outputDirectory": "build",
  "headers": [
    {
      "source": "/static/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/asset-manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/splash",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://vercel-dataflow.vercel.app/api/$1"
    },
    {
      "source": "/p/js/script.js",
      "destination": "https://plausible.io/js/pa-J-f6cbp2d2srW3LByBaYl.js"
    },
    {
      "source": "/p/api/event",
      "destination": "https://plausible.io/api/event"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}